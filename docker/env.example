# Root Docker Compose connects to the existing story_db Postgres via host port 54329.
# Copy to .env at the project root to override any default.
#   cp docker/env.example .env

STORY_DATABASE_URL=postgresql://betterbox:betterbox@host.docker.internal:54329/betterbox_story
STORY_READER_PORT=3000
STORY_ADMIN_PORT=3001

# Admin UI — link "Mở trên reader" (build arg + runtime cho story-admin)
NEXT_PUBLIC_STORY_READER_URL=http://localhost:3000

# Story admin — dịch metadata qua Ollama (cần ollama serve / profile ai)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:14b

# Story admin — gọi pipeline Python (không duplicate logic trong Node)
# Local dev: để trống STORY_PIPELINE_DOCKER, Python mặc định viterbox/venv
STORY_PIPELINE_ROOT=/repo
STORY_PIPELINE_DOCKER=0
# Docker + docker CLI trên host: STORY_PIPELINE_DOCKER=1 → docker compose run story-pipeline-cli
# STORY_PIPELINE_DOCKER_SERVICE=story-pipeline-cli

# COOKIE_SECURE=false applies to both story-reader and story-admin when using HTTP on LAN

# Public site URL for story-reader OG/Twitter images and metadataBase (baked at Docker build).
# Use your real HTTPS origin in production, e.g. https://linhquyencac.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Reader WebSocket + pipeline broadcast (story-reader Docker runs server.js with /reader-ws).
# Generate a strong shared secret once and paste into root .env (do not commit):
#   bash docker/scripts/generate-reader-realtime-token.sh
# Or print ready-to-paste lines:
#   bash docker/scripts/print-reader-realtime-env.sh
# Smoke after deploy:
#   bash docker/scripts/smoke-reader-realtime.sh
# Required in production (NODE_ENV=production): broadcast API returns 401 without it.
READER_REALTIME_TOKEN=
# Browser URL — leave empty to use same host as the page (ws://localhost:3000/reader-ws).
# Behind HTTPS reverse proxy, bake at build time, e.g. wss://your-domain.example/reader-ws
NEXT_PUBLIC_READER_WS_URL=
# Internal Docker URL for crawlers/polish-worker to notify the reader (compose default works).
READER_REALTIME_URL=http://story-reader:3000

# Set COOKIE_SECURE=false when accessing the story-reader over HTTP on a LAN IP
# (e.g. http://192.168.x.x:3000). Without this, the session cookie (Secure flag)
# is rejected by mobile browsers over non-HTTPS connections in production mode.
# Leave unset (or omit) when serving over HTTPS — the default is secure=true.
# COOKIE_SECURE=false

# Reader API gate for on-demand audio. Keep this strict on small machines.
AUDIO_API_BLOCKING_JOB_TYPES=audio_chapter_segments,audio_chapter,polish_chapter
AUDIO_API_MAX_RUNNING_JOBS=1
AUDIO_API_MAX_QUEUED_JOBS=1
AUDIO_API_MIN_FREE_RAM_GB=1.5
AUDIO_API_MAX_LOAD_PER_CPU=0.9
# Set >0 only if story-reader has nvidia-smi/GPU visibility.
AUDIO_API_MIN_FREE_VRAM_GB=0

# ---------------------------------------------------------------------------
# Story discovery — scan catalogs for new stories, upsert to DB (once/day)
# ---------------------------------------------------------------------------
DISCOVERY_INTERVAL_SECONDS=86400
# Default production discovery avoids currently blocked/flaky list sources
# such as hako, manhwatv, and qidian/quiqui-like guarded sites. Add them
# back explicitly only after verifying access.
DISCOVERY_SOURCES=truyenfull_today royalroad
DISCOVERY_PAGES=2
DISCOVERY_MIN_CHAPTERS=30

# ---------------------------------------------------------------------------
# Crawler — pull new chapters for all DB stories (continuous, 5-min passes)
# ---------------------------------------------------------------------------

# Number of parallel crawler containers. Each claims different stories from DB.
# Increase to crawl faster: CRAWLER_REPLICAS=3
CRAWLER_REPLICAS=1

# Max worker threads per container. check_resources.py scales this down when busy.
CRAWLER_WORKERS=4

# Resource thresholds — skip/reduce crawl when system is loaded.
CRAWLER_MIN_FREE_RAM_GB=1.0      # skip pass if free RAM below this (GB)
CRAWLER_MAX_CPU_PERCENT=85       # reduce workers if CPU above this (%)

# Timing
CRAWLER_INTERVAL_SECONDS=300     # pause between passes (seconds)
CRAWLER_MIN_CATALOG_CHECK_HOURS=1   # re-check each story at most once per N hours
CRAWLER_CLAIM_COOLDOWN_MINUTES=60   # don't re-claim a story finished within N minutes

# Scope. Keep a positive allowlist so blocked/flaky sources do not get claimed
# from DB by accident. Override manually if a source is fixed.
CRAWLER_SOURCES=truyenfull_today truyenyy docln sttruyen truyenchuhay truyenhoangdung wattpad_vn royalroad lightnovelpub novelbin freewebnovel novelhub
CRAWLER_ONLY_INCOMPLETE=1
CRAWLER_LIMIT_STORIES=0
CRAWLER_MAX_CHAPTERS=0
CRAWLER_TIMEOUT=30
CRAWLER_RETRIES=5
CRAWLER_RETRY_SLEEP=2.0
CRAWLER_CHAPTER_DELAY=1.5
CRAWLER_CHAPTER_WORKERS=2
CRAWLER_MAX_CONSECUTIVE_CONTENT_MISSES=1
CRAWLER_POST_TRANSLATE=polish

# ---------------------------------------------------------------------------
# Alternate source scheduler — find source B and merge into source-A stories
# ---------------------------------------------------------------------------
ALTERNATE_INTERVAL_SECONDS=21600
# Target source-A stories to inspect. Blocked sources like hako/manhwatv are
# intentionally not in the default target set.
ALTERNATE_TARGET_SOURCES=truyenfull_today truyenyy docln sttruyen truyenchuhay truyenhoangdung wattpad_vn
# English public providers currently supported by auto search. novelbin,
# novelhub, and freewebnovel can be crawled when a story URL is already in DB,
# but are omitted from auto search by default because their public search
# endpoints are flaky or need stronger per-story latest chapter hints.
ALTERNATE_PROVIDERS=lightnovelpub royalroad
ALTERNATE_ALIAS_JSON=
ALTERNATE_LIMIT_STORIES=20
ALTERNATE_MIN_SCORE=0.72
ALTERNATE_MAX_CANDIDATES=5
ALTERNATE_RESUME_FROM=polished
# Keep dry-run first. Set to 1 after checking logs/candidates.
ALTERNATE_APPLY=0
# If 0, imported en/zh/ko chapters enqueue polish_chapter for polish-worker.
# If 1, this scheduler translates/polishes inline and can run much longer.
ALTERNATE_POLISH_INLINE=0
ALTERNATE_POST_TRANSLATE=copy
# heuristic = no LLM, generates deaccented and xianxia/common English aliases.
# both/ollama additionally asks Ollama to guess likely official English titles.
ALTERNATE_ALIAS_INFERENCE=heuristic
ALTERNATE_ALIAS_MODEL=qwen3:14b
ALTERNATE_ALIAS_TIMEOUT=120
ALTERNATE_CHAR_MAP_TEXT_SOURCE=auto
ALTERNATE_CHAR_MAP_MIN_FREQUENCY=1
ALTERNATE_TRANSLATE_FOR_SEARCH=1
ALTERNATE_TRANSLATE_CHECK_TIMEOUT=3
ALTERNATE_ONLY_NEEDS_ALTERNATE=0
ALTERNATE_LOG_SKIPPED_QUERIES=0
ALTERNATE_INCLUDE_COMPLETED=0
ALTERNATE_MAX_CHAPTERS=0
ALTERNATE_TIMEOUT=30
ALTERNATE_RETRIES=3
ALTERNATE_RETRY_SLEEP=2.0
ALTERNATE_SEARCH_DELAY=0.5
ALTERNATE_PROVIDER_FAILURE_LIMIT=1
ALTERNATE_DIRECT_SLUG_CANDIDATES=0
ALTERNATE_CHAPTER_DELAY=1.5
ALTERNATE_REQUEUE_DONE=0
# Empty = auto-discover story_data/story_memory/{story_id}-{slug}; or set a root/exact story-memory dir.
ALTERNATE_STORY_MEMORY_DIR=
# Set 1 only after reviewing warnings; this fails inline polish on detected memory issues.
ALTERNATE_FAIL_ON_STORY_MEMORY_ISSUES=0

# ---------------------------------------------------------------------------
# Polish worker (profile: ai) — Ollama LLM polish/translate
# ---------------------------------------------------------------------------
OLLAMA_URL=http://host.docker.internal:11434
POLISH_WORKERS=1
POLISH_SOURCE_CODES=
POLISH_VI_MODEL=qwen3:14b
POLISH_TRANSLATE_MODEL=qwen3:14b
POLISH_POST_TRANSLATE=polish
# auto = raw for Vietnamese-source stories, translated for English/Korean/Chinese source stories.
POLISH_CHAR_MAP_TEXT_SOURCE=auto
POLISH_CHAR_MAP_MIN_FREQUENCY=1
# Cooldown chapters after a failed initial char-map build; prevents hammering Ollama when busy.
POLISH_CHAR_MAP_CREATE_COOLDOWN=30
# Empty = auto-discover story_data/story_memory/{story_id}-{slug}; or set a root/exact story-memory dir.
POLISH_STORY_MEMORY_DIR=
# Set 1 after tuning memory/glossary; default warns but keeps pipeline moving.
POLISH_FAIL_ON_STORY_MEMORY_ISSUES=0
POLISH_INTERVAL_SECONDS=30
# 1 = DB-only mode: không save translated/polished txt ra disk (mặc định). Set 0 nếu cần files cho debug.
POLISH_NO_SAVE_FILES=1
POLISH_MIN_FREE_RAM_GB=2.0
POLISH_MAX_CPU_PERCENT=80

# Fleet quality pipeline (story_quality_pipeline.py auto)
QUALITY_MIN_VRAM_MB=10240
QUALITY_MIN_RAM_MB=4096
QUALITY_MAX_CPU_PCT=85
FLEET_BATCH_SIZE=30

# VieNeu TTS preview / generation — wait until this much VRAM is free
TTS_MIN_VRAM_MB=6144
TTS_MIN_RAM_MB=6148
TTS_MAX_CPU_PCT=70
TTS_CPU_MIN_RAM_MB=8192
TTS_CPU_MAX_CPU_PCT=55
TTS_MAX_GPU_UTIL_PCT=20
TTS_RESOURCE_POLL_SECONDS=20
TTS_RESOURCE_MAX_WAIT_SECONDS=7200
TTS_PROFILE_COOLDOWN_SECONDS=10
FLEET_DAEMON_IDLE=300

# ---------------------------------------------------------------------------
# Audio enqueuer (profile: audio) — create audio jobs from polished chapters
# ---------------------------------------------------------------------------
AUDIO_ENQUEUE_INTERVAL_SECONDS=1800
AUDIO_ENQUEUE_LIMIT=200
AUDIO_OUTPUT_ROOT=story_audio
AUDIO_ENQUEUE_SOURCES=

# ---------------------------------------------------------------------------
# Audio worker (profile: gpu) — VieNeu-TTS v3 generation
# ---------------------------------------------------------------------------
AUDIO_VIENEU_DEVICE=auto
AUDIO_VIENEU_BACKEND=auto
AUDIO_VIENEU_VOICE=Trọng Hữu
# BetterBox voice-clone profile. Empty means use built-in preset voice from AUDIO_VIENEU_VOICE.
AUDIO_VIENEU_VOICE_PROFILE=preset_trong_huu
# Optional voice-clone reference WAV. Overrides AUDIO_VIENEU_VOICE_PROFILE and AUDIO_VIENEU_VOICE.
AUDIO_VIENEU_REFERENCE_AUDIO=
AUDIO_VIENEU_REFERENCE_TEXT=

# ---------------------------------------------------------------------------
# Audio segment worker (profile: gpu) — low-latency first-play chapter audio
# ---------------------------------------------------------------------------
AUDIO_SEGMENT_VIENEU_DEVICE=auto
AUDIO_SEGMENT_VIENEU_BACKEND=auto
AUDIO_SEGMENT_VIENEU_MIN_FREE_VRAM_GB=6
AUDIO_SEGMENT_MIN_FREE_RAM_GB=1.5
AUDIO_SEGMENT_MAX_CPU_PERCENT=90
AUDIO_SEGMENT_RESOURCE_WAIT_SECONDS=10
AUDIO_SEGMENT_OUTPUT_ROOT=story_audio_segments
AUDIO_SEGMENT_VIENEU_VOICE_KEY=preset_trong_huu
AUDIO_SEGMENT_VIENEU_VOICE=Trọng Hữu
# BetterBox voice-clone profile. Empty means use built-in preset voice from AUDIO_SEGMENT_VIENEU_VOICE.
AUDIO_SEGMENT_VIENEU_VOICE_PROFILE=preset_trong_huu
# Optional voice-clone reference WAV. Overrides AUDIO_SEGMENT_VIENEU_VOICE_PROFILE and AUDIO_SEGMENT_VIENEU_VOICE.
AUDIO_SEGMENT_VIENEU_REFERENCE_AUDIO=
AUDIO_SEGMENT_VIENEU_REFERENCE_TEXT=
AUDIO_SEGMENT_GPU_LOCK_PATH=/tmp/betterbox_tts_gpu.lock
